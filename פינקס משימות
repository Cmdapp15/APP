<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>משימות לביצוע</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Assistant:wght@300;400;700&display=swap');
        
        body {
            font-family: 'Assistant', sans-serif;
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            min-height: 100vh;
        }

        .completed {
            text-decoration: line-through;
            opacity: 0.6;
        }
    </style>
</head>
<body class="flex items-center justify-center p-4">

    <div class="bg-white p-8 rounded-2xl shadow-xl w-full max-w-md">
        <h1 class="text-3xl font-bold text-gray-800 mb-6 text-center">המשימות שלי</h1>
        
        <!-- אזור הזנה -->
        <div class="flex gap-2 mb-6">
            <input type="text" id="todoInput" placeholder="מה צריך לעשות?" 
                   class="flex-1 p-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 text-lg">
            <button onclick="addTodo()" 
                    class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded-lg font-bold transition-colors">
                הוסף
            </button>
        </div>

        <!-- רשימת המשימות -->
        <ul id="todoList" class="space-y-3">
            <!-- משימות יופיעו כאן -->
        </ul>

        <!-- הודעה כשאין משימות -->
        <p id="emptyMsg" class="text-gray-400 text-center mt-4">אין משימות כרגע, תהנו מהזמן החופשי!</p>
    </div>

    <script>
        const input = document.getElementById('todoInput');
        const list = document.getElementById('todoList');
        const emptyMsg = document.getElementById('emptyMsg');

        // הוספת משימה בלחיצה על Enter
        input.addEventListener('keypress', (e) => {
            if (e.key === 'Enter') addTodo();
        });

        function addTodo() {
            const text = input.value.trim();
            if (text === "") return;

            const li = document.createElement('li');
            li.className = "flex items-center justify-between bg-gray-50 p-4 rounded-xl border border-gray-100 shadow-sm hover:shadow-md transition-shadow group";
            
            li.innerHTML = `
                <div class="flex items-center gap-3 cursor-pointer flex-1" onclick="toggleComplete(this)">
                    <div class="w-6 h-6 border-2 border-blue-500 rounded-full flex items-center justify-center bg-white check-icon">
                        <div class="hidden w-3 h-3 bg-blue-500 rounded-full"></div>
                    </div>
                    <span class="text-gray-700 text-lg todo-text">${text}</span>
                </div>
                <button onclick="removeTodo(this)" class="text-red-400 hover:text-red-600 transition-colors p-1 opacity-0 group-hover:opacity-100">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                    </svg>
                </button>
            `;

            list.appendChild(li);
            input.value = "";
            updateEmptyMessage();
        }

        function toggleComplete(element) {
            const textSpan = element.querySelector('.todo-text');
            const checkMark = element.querySelector('.check-icon div');
            
            textSpan.classList.toggle('completed');
            checkMark.classList.toggle('hidden');
        }

        function removeTodo(button) {
            button.closest('li').remove();
            updateEmptyMessage();
        }

        function updateEmptyMessage() {
            if (list.children.length > 0) {
                emptyMsg.classList.add('hidden');
            } else {
                emptyMsg.classList.remove('hidden');
            }
        }
    </script>
</body>
</html>
