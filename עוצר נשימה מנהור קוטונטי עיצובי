<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cosmic Horizon | חוויה ויזואלית פורצת דרך</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Assistant:wght@200;400;700&display=swap');

        body {
            margin: 0;
            padding: 0;
            overflow: hidden;
            background-color: #050505;
            font-family: 'Assistant', sans-serif;
            color: white;
        }

        #canvas-container {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
        }

        .ui-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            padding: 40px;
            box-sizing: border-box;
            background: radial-gradient(circle at center, transparent 0%, rgba(0,0,0,0.4) 100%);
            z-index: 10;
        }

        .header {
            opacity: 0;
            transform: translateY(-20px);
            animation: fadeInDown 1.5s forwards ease-out;
        }

        h1 {
            font-weight: 200;
            font-size: clamp(2rem, 5vw, 4rem);
            margin: 0;
            letter-spacing: 8px;
            text-transform: uppercase;
            background: linear-gradient(to right, #fff, #4facfe, #00f2fe);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .footer {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            opacity: 0;
            animation: fadeInUp 1.5s 0.5s forwards ease-out;
        }

        .info-box {
            max-width: 300px;
            border-right: 1px solid rgba(255,255,255,0.3);
            padding-right: 20px;
        }

        .info-box p {
            font-size: 0.9rem;
            line-height: 1.6;
            color: rgba(255,255,255,0.7);
        }

        .controls-hint {
            text-align: left;
            font-size: 0.8rem;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: #4facfe;
        }

        @keyframes fadeInDown {
            to { opacity: 1; transform: translateY(0); }
        }

        @keyframes fadeInUp {
            to { opacity: 1; transform: translateY(0); }
        }

        .loader {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            z-index: 100;
            text-align: center;
            transition: opacity 1s;
        }

        .loader.hidden {
            opacity: 0;
            pointer-events: none;
        }

        .spinner {
            width: 50px;
            height: 50px;
            border: 2px solid rgba(255,255,255,0.1);
            border-top: 2px solid #4facfe;
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin-bottom: 20px;
        }

        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
    </style>
</head>
<body>

    <div class="loader" id="loader">
        <div class="spinner"></div>
        <p>מכין את היקום עבורך...</p>
    </div>

    <div id="canvas-container"></div>

    <div class="ui-overlay">
        <div class="header">
            <h1>COSMIC HORIZON</h1>
            <p style="letter-spacing: 3px; font-weight: 400; opacity: 0.8;">הגבול האחרון של העיצוב</p>
        </div>

        <div class="footer">
            <div class="info-box">
                <p>סימולציה תלת-ממדית בזמן אמת המשתמשת באלגוריתמי זרימה קוונטיים ליצירת מרחב ויזואלי אינסופי.</p>
            </div>
            <div class="controls-hint">
                הזז את העכבר כדי לשלוט בזמן <br>
                לחץ וגרור כדי לסובב את המבט
            </div>
        </div>
    </div>

    <script>
        let scene, camera, renderer, particles, sphere, torus;
        let mouseX = 0, mouseY = 0;
        let targetX = 0, targetY = 0;
        let windowHalfX = window.innerWidth / 2;
        let windowHalfY = window.innerHeight / 2;
        let clock = new THREE.Clock();

        function init() {
            // Scene Setup
            scene = new THREE.Scene();
            scene.fog = new THREE.FogExp2(0x050505, 0.002);

            camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 2000);
            camera.position.z = 400;

            renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
            renderer.setPixelRatio(window.devicePixelRatio);
            renderer.setSize(window.innerWidth, window.innerHeight);
            document.getElementById('canvas-container').appendChild(renderer.domElement);

            // Creation of Stars/Particles
            const geometry = new THREE.BufferGeometry();
            const vertices = [];
            const colors = [];
            const color = new THREE.Color();

            for (let i = 0; i < 15000; i++) {
                vertices.push(
                    Math.random() * 2000 - 1000,
                    Math.random() * 2000 - 1000,
                    Math.random() * 2000 - 1000
                );

                const vx = (Math.random() * 0.5) + 0.5;
                const vy = (Math.random() * 0.5) + 0.5;
                const vz = 1.0;
                color.setRGB(vx, vy, vz);
                colors.push(color.r, color.g, color.b);
            }

            geometry.setAttribute('position', new THREE.Float32BufferAttribute(vertices, 3));
            geometry.setAttribute('color', new THREE.Float32BufferAttribute(colors, 3));

            const material = new THREE.PointsMaterial({
                size: 2,
                vertexColors: true,
                transparent: true,
                opacity: 0.8,
                blending: THREE.AdditiveBlending
            });

            particles = new THREE.Points(geometry, material);
            scene.add(particles);

            // Core Object - Mathematical Wireframe
            const torusGeo = new THREE.TorusKnotGeometry(100, 30, 200, 32);
            const torusMat = new THREE.MeshPhongMaterial({
                color: 0x4facfe,
                wireframe: true,
                emissive: 0x112244,
                shininess: 100
            });
            torus = new THREE.Mesh(torusGeo, torusMat);
            scene.add(torus);

            // Inner Core Glow
            const sphereGeo = new THREE.SphereGeometry(40, 32, 32);
            const sphereMat = new THREE.MeshBasicMaterial({
                color: 0xffffff,
                transparent: true,
                opacity: 0.2
            });
            sphere = new THREE.Mesh(sphereGeo, sphereMat);
            scene.add(sphere);

            // Lighting
            const pLight1 = new THREE.PointLight(0x00f2fe, 2, 500);
            pLight1.position.set(200, 100, 100);
            scene.add(pLight1);

            const pLight2 = new THREE.PointLight(0x4facfe, 2, 500);
            pLight2.position.set(-200, -100, 100);
            scene.add(pLight2);

            const ambientLight = new THREE.AmbientLight(0x111111);
            scene.add(ambientLight);

            // Events
            document.addEventListener('mousemove', onDocumentMouseMove);
            window.addEventListener('resize', onWindowResize);
            
            // Interaction for touch
            document.addEventListener('touchstart', (e) => {
                if(e.touches.length > 0) {
                    mouseX = e.touches[0].clientX - windowHalfX;
                    mouseY = e.touches[0].clientY - windowHalfY;
                }
            }, {passive: true});

            // Start loop
            animate();
            
            // Hide loader
            setTimeout(() => {
                document.getElementById('loader').classList.add('hidden');
            }, 1000);
        }

        function onWindowResize() {
            windowHalfX = window.innerWidth / 2;
            windowHalfY = window.innerHeight / 2;
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        }

        function onDocumentMouseMove(event) {
            mouseX = (event.clientX - windowHalfX) * 0.5;
            mouseY = (event.clientY - windowHalfY) * 0.5;
        }

        function animate() {
            requestAnimationFrame(animate);
            render();
        }

        function render() {
            const time = clock.getElapsedTime();

            // Smooth camera movement
            targetX = mouseX * .001;
            targetY = mouseY * .001;

            camera.position.x += (mouseX - camera.position.x) * 0.05;
            camera.position.y += (-mouseY - camera.position.y) * 0.05;
            camera.lookAt(scene.position);

            // Animate Particles
            particles.rotation.y = time * 0.05;
            particles.rotation.x = time * 0.02;

            // Animate Core Torus
            torus.rotation.x = time * 0.2;
            torus.rotation.y = time * 0.3;
            
            // Pulse Effect
            const scale = 1 + Math.sin(time * 2) * 0.1;
            sphere.scale.set(scale, scale, scale);
            sphere.material.opacity = 0.1 + Math.abs(Math.sin(time)) * 0.2;

            // Floating movement
            torus.position.y = Math.sin(time * 0.5) * 20;

            renderer.render(scene, camera);
        }

        window.onload = init;
    </script>
</body>
</html>
