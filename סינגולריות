<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>הסינגולריות - חוויה קוסמית</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Assistant:wght@200;400;700&display=swap" rel="stylesheet">
    <style>
        body {
            margin: 0;
            overflow: hidden;
            background-color: #050505;
            font-family: 'Assistant', sans-serif;
            color: #fff;
        }

        #canvas-container {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
        }

        .glass-ui {
            background: rgba(10, 10, 20, 0.15);
            backdrop-filter: blur(25px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 24px;
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.9);
        }

        .control-panel {
            position: fixed;
            top: 20px;
            right: 20px;
            width: 320px;
            padding: 24px;
            z-index: 100;
            border-top: 2px solid rgba(99, 102, 241, 0.5);
        }

        .stats-panel {
            position: fixed;
            bottom: 20px;
            left: 20px;
            padding: 15px 25px;
            z-index: 100;
            border-left: 4px solid #6366f1;
        }

        .btn-action {
            background: linear-gradient(90deg, #6366f1, #d946ef);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            text-shadow: 0 0 10px rgba(0,0,0,0.5);
        }

        .btn-action:hover {
            transform: scale(1.02);
            filter: brightness(1.2);
            box-shadow: 0 0 30px rgba(217, 70, 239, 0.4);
        }

        input[type=range] {
            accent-color: #d946ef;
            height: 4px;
        }

        .loading-screen {
            position: fixed;
            inset: 0;
            background: radial-gradient(circle at center, #111 0%, #000 100%);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            z-index: 1000;
        }

        .shimmer {
            background: linear-gradient(90deg, #6366f1, #d946ef, #6366f1);
            background-size: 200% auto;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            animation: move-shimmer 2s linear infinite;
        }

        @keyframes move-shimmer {
            to { background-position: 200% center; }
        }

        /* Scanline Effect */
        body::after {
            content: " ";
            position: fixed;
            top: 0; left: 0; width: 100vw; height: 100vh;
            background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.1) 50%), 
                        linear-gradient(90deg, rgba(255, 0, 0, 0.02), rgba(0, 255, 0, 0.01), rgba(0, 0, 255, 0.02));
            background-size: 100% 2px, 3px 100%;
            pointer-events: none;
            z-index: 200;
        }
    </style>
</head>
<body>

    <div id="loading" class="loading-screen">
        <div class="mb-8 relative">
            <div class="w-24 h-24 rounded-full border-b-2 border-fuchsia-500 animate-spin"></div>
            <div class="absolute inset-0 flex items-center justify-center font-bold text-fuchsia-500">BH</div>
        </div>
        <h1 class="text-3xl font-light tracking-[0.3em] shimmer uppercase">Singularity OS</h1>
        <p class="mt-2 opacity-40 text-xs">CALIBRATING SPACE-TIME CONTINUUM...</p>
    </div>

    <div id="canvas-container"></div>

    <div class="control-panel glass-ui">
        <div class="flex justify-between items-center mb-6">
            <h2 class="text-xl font-bold tracking-tight">מרכז הסינגולריות</h2>
            <span class="px-2 py-1 rounded bg-fuchsia-500/20 text-[10px] text-fuchsia-400 font-mono">V 2.0</span>
        </div>
        
        <div class="space-y-6">
            <div>
                <div class="flex justify-between text-xs mb-2 opacity-60">
                    <span>עיוות מרחב-זמן</span>
                    <span id="speed-val">1.0x</span>
                </div>
                <input type="range" id="speed" min="0" max="0.1" step="0.001" value="0.01" class="w-full">
            </div>

            <div>
                <div class="flex justify-between text-xs mb-2 opacity-60">
                    <span>צפיפות מסה</span>
                    <span id="density-val">12k</span>
                </div>
                <input type="range" id="density" min="2000" max="40000" step="1000" value="15000" class="w-full">
            </div>

            <div class="pt-4 border-t border-white/5 space-y-3">
                <button id="hyperdrive" class="btn-action w-full py-3 rounded-xl font-bold text-xs tracking-widest uppercase">
                    הפעל היפר-דרייב (Warp)
                </button>
                <button id="collapse" class="w-full py-3 rounded-xl border border-white/10 text-xs font-bold hover:bg-white/5 transition-all">
                    קריסה כבידתית
                </button>
            </div>
        </div>
    </div>

    <div class="stats-panel glass-ui">
        <div class="grid grid-cols-2 gap-x-8 gap-y-1">
            <span class="text-[10px] opacity-40 uppercase">Horizon Radius</span>
            <span class="text-[10px] opacity-40 uppercase">Entropy Level</span>
            <span id="horizon-val" class="text-xs font-mono">1.429 AU</span>
            <span id="entropy-val" class="text-xs font-mono text-fuchsia-400">99.2%</span>
        </div>
    </div>

    <script>
        let scene, camera, renderer, starSystem, blackHole, accretionDisk;
        let mouseX = 0, mouseY = 0;
        let isWarping = false;
        let warpFactor = 0;
        
        // Particles Data
        let particlesCount = 15000;
        let particleData = [];

        const init = () => {
            scene = new THREE.Scene();
            camera = new THREE.PerspectiveCamera(60, window.innerWidth / window.innerHeight, 1, 3000);
            camera.position.z = 600;

            renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
            renderer.setSize(window.innerWidth, window.innerHeight);
            renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
            document.getElementById('canvas-container').appendChild(renderer.domElement);

            createBlackHole();
            createStarSystem(particlesCount);
            
            window.addEventListener('resize', onWindowResize);
            document.addEventListener('mousemove', (e) => {
                mouseX = (e.clientX - window.innerWidth / 2) * 0.5;
                mouseY = (e.clientY - window.innerHeight / 2) * 0.5;
            });

            document.getElementById('hyperdrive').addEventListener('click', () => {
                isWarping = !isWarping;
                document.getElementById('hyperdrive').innerText = isWarping ? "עצור היפר-דרייב" : "הפעל היפר-דרייב (Warp)";
            });

            document.getElementById('collapse').addEventListener('click', collapseEffect);

            // Close loading
            setTimeout(() => {
                document.getElementById('loading').style.opacity = '0';
                setTimeout(() => document.getElementById('loading').remove(), 1000);
            }, 2500);

            animate();
        };

        function createBlackHole() {
            // The Core (Void)
            const coreGeo = new THREE.SphereGeometry(40, 32, 32);
            const coreMat = new THREE.MeshBasicMaterial({ color: 0x000000 });
            blackHole = new THREE.Mesh(coreGeo, coreMat);
            scene.add(blackHole);

            // Accretion Disk (The glowing ring)
            const diskGeo = new THREE.TorusGeometry(80, 20, 2, 100);
            const diskMat = new THREE.MeshBasicMaterial({ 
                color: 0xf59e0b, 
                wireframe: true, 
                transparent: true, 
                opacity: 0.3,
                blending: THREE.AdditiveBlending 
            });
            accretionDisk = new THREE.Mesh(diskGeo, diskMat);
            accretionDisk.rotation.x = Math.PI / 2;
            scene.add(accretionDisk);
        }

        function createStarSystem(count) {
            if(starSystem) scene.remove(starSystem);
            
            const geo = new THREE.BufferGeometry();
            const pos = new Float32Array(count * 3);
            const colors = new Float32Array(count * 3);
            particleData = [];

            for(let i=0; i<count; i++) {
                // Spiral formation
                const angle = Math.random() * Math.PI * 2;
                const radius = 100 + Math.random() * 600;
                const spiral = radius * 0.1;
                
                const x = Math.cos(angle + radius * 0.01) * radius;
                const y = (Math.random() - 0.5) * (radius * 0.2);
                const z = Math.sin(angle + radius * 0.01) * radius;

                pos[i*3] = x;
                pos[i*3+1] = y;
                pos[i*3+2] = z;

                particleData.push({
                    angle: angle,
                    radius: radius,
                    speed: (0.001 + Math.random() * 0.005) * (600 / radius),
                    yVar: y
                });

                const color = new THREE.Color();
                const hue = radius < 250 ? 0.05 : radius < 450 ? 0.7 : 0.6;
                color.setHSL(hue + (Math.random() * 0.1), 0.8, 0.6);
                colors[i*3] = color.r;
                colors[i*3+1] = color.g;
                colors[i*3+2] = color.b;
            }

            geo.setAttribute('position', new THREE.BufferAttribute(pos, 3));
            geo.setAttribute('color', new THREE.BufferAttribute(colors, 3));

            const mat = new THREE.PointsMaterial({
                size: 2,
                vertexColors: true,
                transparent: true,
                opacity: 0.6,
                blending: THREE.AdditiveBlending
            });

            starSystem = new THREE.Points(geo, mat);
            scene.add(starSystem);
        }

        function collapseEffect() {
            particleData.forEach(p => p.radius *= 0.2);
            setTimeout(() => {
                createStarSystem(particlesCount);
            }, 1000);
        }

        function onWindowResize() {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        }

        function animate() {
            requestAnimationFrame(animate);

            const baseSpeed = parseFloat(document.getElementById('speed').value);
            const positions = starSystem.geometry.attributes.position.array;

            // Update particles
            for(let i=0; i<particlesCount; i++) {
                const p = particleData[i];
                
                if (isWarping) {
                    warpFactor = THREE.MathUtils.lerp(warpFactor, 10, 0.01);
                } else {
                    warpFactor = THREE.MathUtils.lerp(warpFactor, 1, 0.05);
                }

                p.angle += p.speed * (baseSpeed * 100) * (isWarping ? warpFactor : 1);
                
                // Pull effect toward center
                if(!isWarping) {
                    p.radius -= 0.02; 
                    if(p.radius < 40) p.radius = 600 + Math.random() * 100;
                }

                const x = Math.cos(p.angle) * p.radius;
                const z = Math.sin(p.angle) * p.radius;
                
                positions[i*3] = x;
                positions[i*3+1] = p.yVar * (isWarping ? 0.1 : 1);
                positions[i*3+2] = z;
            }

            starSystem.geometry.attributes.position.needsUpdate = true;
            
            // Black Hole Animation
            accretionDisk.rotation.z += 0.02;
            accretionDisk.scale.setScalar(1 + Math.sin(Date.now() * 0.005) * 0.1);
            
            // Camera Interaction
            camera.position.x += (mouseX - camera.position.x) * 0.05;
            camera.position.y += (-mouseY - camera.position.y) * 0.05;
            camera.lookAt(scene.position);

            // Dynamic UI Stats
            document.getElementById('horizon-val').innerText = (1.4 + Math.random() * 0.1).toFixed(3) + " AU";
            document.getElementById('entropy-val').innerText = (95 + Math.random() * 5).toFixed(1) + "%";

            renderer.render(scene, camera);
        }

        // Listen for density changes
        document.getElementById('density').addEventListener('change', (e) => {
            particlesCount = parseInt(e.target.value);
            document.getElementById('density-val').innerText = (particlesCount/1000).toFixed(0) + "k";
            createStarSystem(particlesCount);
        });

        document.getElementById('speed').addEventListener('input', (e) => {
            document.getElementById('speed-val').innerText = (parseFloat(e.target.value) * 100).toFixed(1) + "x";
        });

        window.onload = init;
    </script>
</body>
</html>
