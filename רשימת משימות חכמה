<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>רשימת המשימות החכמה שלי</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Assistant:wght@300;400;700&display=swap');
        
        body {
            font-family: 'Assistant', sans-serif;
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            min-height: 100vh;
        }

        .todo-item {
            transition: all 0.3s ease;
        }

        .todo-item:hover {
            transform: translateX(-5px);
        }

        .completed {
            text-decoration: line-through;
            opacity: 0.6;
        }

        .loading-shimmer {
            background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
            background-size: 200% 100%;
            animation: shimmer 1.5s infinite;
        }

        @keyframes shimmer {
            0% { background-position: 200% 0; }
            100% { background-position: -200% 0; }
        }
    </style>
</head>
<body class="p-4 md:p-8">

    <div class="max-w-md mx-auto bg-white rounded-2xl shadow-xl overflow-hidden">
        <div class="bg-indigo-600 p-6 text-white text-center">
            <h1 class="text-2xl font-bold">המשימות שלי ✨</h1>
            <p class="text-indigo-100 text-sm mt-1">ניהול חכם מבוסס AI</p>
        </div>

        <div class="p-6">
            <!-- Task Input Section -->
            <div class="flex flex-col gap-2 mb-6">
                <div class="flex gap-2">
                    <input type="text" id="todoInput" 
                        placeholder="מה עלינו לעשות היום?" 
                        class="flex-1 px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500 transition-all">
                    <button onclick="addTodo()" 
                        class="bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded-lg font-bold transition-colors">
                        הוספה
                    </button>
                </div>
            </div>

            <!-- AI Magic Buttons -->
            <div class="flex gap-2 mb-6">
                <button onclick="suggestTasks()" id="aiSuggestBtn"
                    class="flex-1 text-sm bg-purple-100 text-purple-700 hover:bg-purple-200 px-3 py-2 rounded-lg font-medium transition-all flex items-center justify-center gap-1 border border-purple-200">
                    <span>✨ הצע משימות להיום</span>
                </button>
            </div>

            <!-- Task List -->
            <ul id="todoList" class="space-y-3">
                <!-- Tasks added here -->
            </ul>

            <!-- AI Feedback Area -->
            <div id="aiFeedback" class="hidden mt-4 p-3 bg-blue-50 border border-blue-100 rounded-lg text-sm text-blue-800">
                <div id="aiFeedbackContent"></div>
            </div>

            <!-- Empty State -->
            <div id="emptyState" class="text-center py-10 text-gray-400">
                <p>אין משימות כרגע. אפשר לנוח!</p>
            </div>
        </div>
    </div>

    <script>
        const apiKey = ""; // API key is handled by the environment
        const input = document.getElementById('todoInput');
        const list = document.getElementById('todoList');
        const emptyState = document.getElementById('emptyState');
        const aiFeedback = document.getElementById('aiFeedback');
        const aiFeedbackContent = document.getElementById('aiFeedbackContent');

        // --- Gemini API Call Implementation ---
        async function callGemini(prompt) {
            let delay = 1000;
            for (let i = 0; i < 5; i++) {
                try {
                    const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            contents: [{ parts: [{ text: prompt }] }],
                            systemInstruction: {
                                parts: [{ text: "You are a helpful productivity assistant. Always respond in Hebrew." }]
                            }
                        })
                    });
                    
                    if (!response.ok) throw new Error('API request failed');
                    
                    const result = await response.json();
                    return result.candidates?.[0]?.content?.parts?.[0]?.text;
                } catch (error) {
                    if (i === 4) throw error;
                    await new Promise(resolve => setTimeout(resolve, delay));
                    delay *= 2;
                }
            }
        }

        // --- Feature: Breakdown Task into Subtasks ---
        async function breakDownTask(taskText, button) {
            const originalIcon = button.innerHTML;
            button.innerHTML = `<span class="inline-block animate-spin">⏳</span>`;
            button.disabled = true;

            try {
                const prompt = `קח את המשימה הבאה: "${taskText}" ופרק אותה ל-3 עד 5 תתי-משימות קצרות וברורות שיעזרו לי להשלים אותה. החזר רק את המשימות בפורמט של רשימה, מופרדות בפסיקים.`;
                const response = await callGemini(prompt);
                
                if (response) {
                    const subtasks = response.split(',').map(s => s.trim()).filter(s => s.length > 0);
                    subtasks.forEach(sub => {
                        createTodoElement(`[${taskText}] ${sub}`);
                    });
                }
            } catch (error) {
                console.error("AI Error:", error);
            } finally {
                button.innerHTML = originalIcon;
                button.disabled = false;
            }
        }

        // --- Feature: Suggest Daily Tasks based on context ---
        async function suggestTasks() {
            const btn = document.getElementById('aiSuggestBtn');
            const originalText = btn.innerHTML;
            btn.innerHTML = "✨ מתכנן עבורך...";
            btn.disabled = true;

            try {
                const prompt = "הצע לי 3 משימות פרודוקטיביות ומגוונות שאני יכול לעשות היום כדי להרגיש סיפוק. החזר רק את שמות המשימות מופרדים בפסיקים, בעברית.";
                const response = await callGemini(prompt);
                
                if (response) {
                    const suggestions = response.split(',').map(s => s.trim());
                    suggestions.forEach(task => createTodoElement(task));
                    
                    aiFeedback.classList.remove('hidden');
                    aiFeedbackContent.innerText = "✨ ג'מיני הציע כמה משימות כדי לשפר לך את היום!";
                }
            } catch (error) {
                console.error("AI Error:", error);
            } finally {
                btn.innerHTML = originalText;
                btn.disabled = false;
            }
        }

        function createTodoElement(text) {
            const li = document.createElement('li');
            li.className = "todo-item flex items-center justify-between p-3 bg-gray-50 rounded-lg border border-gray-100 shadow-sm";
            
            li.innerHTML = `
                <div class="flex items-center gap-3 flex-1 overflow-hidden">
                    <input type="checkbox" onchange="toggleComplete(this)" class="w-5 h-5 cursor-pointer accent-indigo-600">
                    <span class="text-gray-700 truncate">${text}</span>
                </div>
                <div class="flex items-center gap-2">
                    <button onclick="breakDownTask('${text.replace(/'/g, "\\'")}', this)" 
                        title="פרק למשימות קטנות ✨"
                        class="text-purple-500 hover:text-purple-700 transition-colors p-1">
                        ✨
                    </button>
                    <button onclick="removeTodo(this)" class="text-red-400 hover:text-red-600 transition-colors p-1">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                        </svg>
                    </button>
                </div>
            `;

            list.appendChild(li);
            updateEmptyState();
        }

        function addTodo() {
            const text = input.value.trim();
            if (text === "") return;
            createTodoElement(text);
            input.value = "";
        }

        function toggleComplete(checkbox) {
            const textSpan = checkbox.nextElementSibling;
            if (checkbox.checked) {
                textSpan.classList.add('completed');
            } else {
                textSpan.classList.remove('completed');
            }
        }

        function removeTodo(button) {
            button.closest('li').remove();
            updateEmptyState();
        }

        function updateEmptyState() {
            if (list.children.length > 0) {
                emptyState.style.display = 'none';
            } else {
                emptyState.style.display = 'block';
            }
        }

        input.addEventListener('keypress', function (e) {
            if (e.key === 'Enter') {
                addTodo();
            }
        });
    </script>
</body>
</html>
