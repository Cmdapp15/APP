<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>משחק תפוס את הכדור</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body {
            margin: 0;
            overflow: hidden;
            touch-action: none;
            font-family: system-ui, -apple-system, sans-serif;
        }
        canvas {
            display: block;
            background: linear-gradient(to bottom, #1e3a8a, #3b82f6);
        }
        #ui-layer {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            padding: 20px;
            pointer-events: none;
            color: white;
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
        }
        .message-box {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            background: rgba(255, 255, 255, 0.95);
            padding: 2rem;
            border-radius: 1rem;
            text-align: center;
            box-shadow: 0 10px 25px rgba(0,0,0,0.2);
            pointer-events: auto;
            display: none;
        }
    </style>
</head>
<body>

    <div id="ui-layer">
        <div class="text-2xl font-bold">ניקוד: <span id="score">0</span></div>
        <div class="text-2xl font-bold">חיים: <span id="lives">3</span></div>
    </div>

    <div id="start-screen" class="message-box" style="display: block;">
        <h1 class="text-3xl font-bold mb-4 text-blue-600">תפוס את הכדור!</h1>
        <p class="mb-6 text-gray-600">הזז את המשטח כדי לתפוס את הכדורים הנופלים.</p>
        <button onclick="startGame()" class="bg-blue-500 hover:bg-blue-600 text-white px-8 py-3 rounded-full font-bold transition-all">התחל משחק</button>
    </div>

    <div id="game-over-screen" class="message-box">
        <h1 class="text-3xl font-bold mb-2 text-red-600">המשחק נגמר!</h1>
        <p id="final-score" class="text-xl mb-6 text-gray-700 font-semibold"></p>
        <button onclick="startGame()" class="bg-green-500 hover:bg-green-600 text-white px-8 py-3 rounded-full font-bold transition-all">נסה שוב</button>
    </div>

    <canvas id="gameCanvas"></canvas>

    <script>
        const canvas = document.getElementById('gameCanvas');
        const ctx = canvas.getContext('2d');
        const scoreEl = document.getElementById('score');
        const livesEl = document.getElementById('lives');
        const startScreen = document.getElementById('start-screen');
        const gameOverScreen = document.getElementById('game-over-screen');
        const finalScoreEl = document.getElementById('final-score');

        let score = 0;
        let lives = 3;
        let gameActive = false;
        let balls = [];
        let paddle = {
            width: 100,
            height: 20,
            x: 0,
            y: 0,
            color: '#fbbf24'
        };

        // התאמת גודל הקנבס למסך
        function resize() {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
            paddle.y = canvas.height - 40;
            paddle.x = (canvas.width - paddle.width) / 2;
        }

        window.addEventListener('resize', resize);
        resize();

        // שליטה (עכבר ומגע)
        function movePaddle(e) {
            let clientX = e.touches ? e.touches[0].clientX : e.clientX;
            paddle.x = clientX - paddle.width / 2;
            
            // הגבלה לקצוות המסך
            if (paddle.x < 0) paddle.x = 0;
            if (paddle.x + paddle.width > canvas.width) paddle.x = canvas.width - paddle.width;
        }

        window.addEventListener('mousemove', movePaddle);
        window.addEventListener('touchmove', (e) => {
            e.preventDefault();
            movePaddle(e);
        }, { passive: false });

        function createBall() {
            if (!gameActive) return;
            balls.push({
                x: Math.random() * (canvas.width - 20) + 10,
                y: -20,
                radius: 10 + Math.random() * 10,
                speed: 3 + Math.random() * 4 + (score / 10), // המהירות עולה עם הניקוד
                color: `hsl(${Math.random() * 360}, 70%, 60%)`
            });
            
            // יצירת כדור חדש במרווח זמן משתנה
            setTimeout(createBall, Math.max(300, 1000 - score * 20));
        }

        function startGame() {
            score = 0;
            lives = 3;
            balls = [];
            gameActive = true;
            scoreEl.textContent = score;
            livesEl.textContent = lives;
            startScreen.style.display = 'none';
            gameOverScreen.style.display = 'none';
            createBall();
            animate();
        }

        function gameOver() {
            gameActive = false;
            finalScoreEl.textContent = `צברת ${score} נקודות!`;
            gameOverScreen.style.display = 'block';
        }

        function animate() {
            if (!gameActive) return;

            ctx.clearRect(0, 0, canvas.width, canvas.height);

            // ציור המשטח
            ctx.fillStyle = paddle.color;
            ctx.shadowBlur = 15;
            ctx.shadowColor = 'rgba(0,0,0,0.3)';
            ctx.beginPath();
            ctx.roundRect(paddle.x, paddle.y, paddle.width, paddle.height, 10);
            ctx.fill();
            ctx.shadowBlur = 0;

            // עדכון וציור כדורים
            for (let i = balls.length - 1; i >= 0; i--) {
                let b = balls[i];
                b.y += b.speed;

                // ציור כדור
                ctx.fillStyle = b.color;
                ctx.beginPath();
                ctx.arc(b.x, b.y, b.radius, 0, Math.PI * 2);
                ctx.fill();

                // זיהוי פגיעה במשטח
                if (
                    b.y + b.radius >= paddle.y &&
                    b.x >= paddle.x &&
                    b.x <= paddle.x + paddle.width &&
                    b.y < paddle.y + paddle.height
                ) {
                    balls.splice(i, 1);
                    score++;
                    scoreEl.textContent = score;
                    continue;
                }

                // פספוס כדור
                if (b.y - b.radius > canvas.height) {
                    balls.splice(i, 1);
                    lives--;
                    livesEl.textContent = lives;
                    if (lives <= 0) {
                        gameOver();
                    }
                }
            }

            requestAnimationFrame(animate);
        }
    </script>
</body>
</html>
