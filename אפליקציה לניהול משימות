import React, { useState, useEffect, useMemo } from 'react';
import { 
  Plus, 
  Trash2, 
  CheckCircle2, 
  Circle, 
  Clock, 
  AlertCircle, 
  BarChart3, 
  Settings, 
  Moon, 
  Sun, 
  Search,
  Filter,
  Calendar,
  ChevronRight,
  LayoutGrid,
  List as ListIcon,
  Tag
} from 'lucide-react';

/**
 * Task Master Pro - A comprehensive productivity application
 * Features:
 * - Full CRUD operations for tasks
 * - Priority levels (Low, Medium, High)
 * - Category organization
 * - Real-time statistics and progress tracking
 * - Dark/Light mode support
 * - Search and advanced filtering
 * - Responsive design for all devices
 */

const App = () => {
  // --- State Management ---
  const [tasks, setTasks] = useState(() => {
    const saved = localStorage.getItem('task_master_data');
    return saved ? JSON.parse(saved) : [];
  });
  
  const [isDarkMode, setIsDarkMode] = useState(false);
  const [filter, setFilter] = useState('all'); // all, active, completed
  const [priorityFilter, setPriorityFilter] = useState('all');
  const [searchQuery, setSearchQuery] = useState('');
  const [viewMode, setViewMode] = useState('list'); // list, grid
  
  // Form State
  const [newTaskTitle, setNewTaskTitle] = useState('');
  const [newTaskPriority, setNewTaskPriority] = useState('medium');
  const [newTaskCategory, setNewTaskCategory] = useState('Work');

  // --- Effects ---
  useEffect(() => {
    localStorage.setItem('task_master_data', JSON.stringify(tasks));
  }, [tasks]);

  // --- Logic ---
  const addTask = (e) => {
    e.preventDefault();
    if (!newTaskTitle.trim()) return;

    const newTask = {
      id: Date.now(),
      title: newTaskTitle,
      priority: newTaskPriority,
      category: newTaskCategory,
      completed: false,
      createdAt: new Date().toISOString()
    };

    setTasks([newTask, ...tasks]);
    setNewTaskTitle('');
  };

  const toggleTask = (id) => {
    setTasks(tasks.map(task => 
      task.id === id ? { ...task, completed: !task.completed } : task
    ));
  };

  const deleteTask = (id) => {
    setTasks(tasks.filter(task => task.id !== id));
  };

  // --- Filtering & Sorting ---
  const filteredTasks = useMemo(() => {
    return tasks.filter(task => {
      const matchesStatus = filter === 'all' ? true : 
                          filter === 'completed' ? task.completed : !task.completed;
      const matchesPriority = priorityFilter === 'all' ? true : task.priority === priorityFilter;
      const matchesSearch = task.title.toLowerCase().includes(searchQuery.toLowerCase()) || 
                           task.category.toLowerCase().includes(searchQuery.toLowerCase());
      
      return matchesStatus && matchesPriority && matchesSearch;
    });
  }, [tasks, filter, priorityFilter, searchQuery]);

  // --- Statistics ---
  const stats = {
    total: tasks.length,
    completed: tasks.filter(t => t.completed).length,
    pending: tasks.filter(t => !t.completed).length,
    highPriority: tasks.filter(t => t.priority === 'high' && !t.completed).length
  };

  const completionRate = stats.total > 0 ? Math.round((stats.completed / stats.total) * 100) : 0;

  return (
    <div className={`min-h-screen transition-colors duration-300 ${isDarkMode ? 'bg-slate-900 text-white' : 'bg-gray-50 text-gray-900'}`}>
      
      {/* Navigation Header */}
      <header className={`sticky top-0 z-10 border-b px-6 py-4 flex items-center justify-between ${isDarkMode ? 'bg-slate-800/80 border-slate-700 backdrop-blur-md' : 'bg-white/80 border-gray-200 backdrop-blur-md'}`}>
        <div className="flex items-center gap-2">
          <div className="p-2 bg-indigo-600 rounded-lg text-white">
            <CheckCircle2 size={24} />
          </div>
          <h1 className="text-xl font-bold tracking-tight">Task Master Pro</h1>
        </div>
        
        <div className="flex items-center gap-4">
          <button 
            onClick={() => setIsDarkMode(!isDarkMode)}
            className={`p-2 rounded-full transition-colors ${isDarkMode ? 'hover:bg-slate-700 text-yellow-400' : 'hover:bg-gray-100 text-slate-600'}`}
          >
            {isDarkMode ? <Sun size={20} /> : <Moon size={20} />}
          </button>
          <div className="h-8 w-px bg-gray-300 dark:bg-slate-700 mx-2 hidden md:block"></div>
          <div className="hidden md:flex items-center gap-2">
            <div className="w-8 h-8 rounded-full bg-indigo-500 flex items-center justify-center text-white font-medium text-xs">JD</div>
            <span className="text-sm font-medium">יונתן דיין</span>
          </div>
        </div>
      </header>

      <main className="max-w-7xl mx-auto p-4 md:p-8 grid grid-cols-1 lg:grid-cols-12 gap-8">
        
        {/* Sidebar / Stats Section */}
        <section className="lg:col-span-3 space-y-6">
          <div className={`p-6 rounded-2xl border ${isDarkMode ? 'bg-slate-800 border-slate-700' : 'bg-white border-gray-200 shadow-sm'}`}>
            <h2 className="text-sm font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-4">סקירת פעילות</h2>
            
            <div className="space-y-4">
              <div>
                <div className="flex justify-between text-sm mb-2">
                  <span>אחוז ביצוע</span>
                  <span className="font-bold">{completionRate}%</span>
                </div>
                <div className="w-full h-2 bg-gray-200 dark:bg-slate-700 rounded-full overflow-hidden">
                  <div 
                    className="h-full bg-indigo-500 transition-all duration-500" 
                    style={{ width: `${completionRate}%` }}
                  ></div>
                </div>
              </div>

              <div className="grid grid-cols-2 gap-3 pt-2">
                <div className={`p-3 rounded-xl ${isDarkMode ? 'bg-slate-700/50' : 'bg-gray-50'}`}>
                  <p className="text-xs text-gray-500 mb-1">משימות</p>
                  <p className="text-xl font-bold">{stats.total}</p>
                </div>
                <div className={`p-3 rounded-xl ${isDarkMode ? 'bg-green-500/10' : 'bg-green-50'}`}>
                  <p className="text-xs text-green-600 mb-1">בוצעו</p>
                  <p className="text-xl font-bold text-green-600">{stats.completed}</p>
                </div>
                <div className={`p-3 rounded-xl ${isDarkMode ? 'bg-blue-500/10' : 'bg-blue-50'}`}>
                  <p className="text-xs text-blue-600 mb-1">ממתינות</p>
                  <p className="text-xl font-bold text-blue-600">{stats.pending}</p>
                </div>
                <div className={`p-3 rounded-xl ${isDarkMode ? 'bg-red-500/10' : 'bg-red-50'}`}>
                  <p className="text-xs text-red-600 mb-1">דחופות</p>
                  <p className="text-xl font-bold text-red-600">{stats.highPriority}</p>
                </div>
              </div>
            </div>
          </div>

          <div className={`p-6 rounded-2xl border ${isDarkMode ? 'bg-slate-800 border-slate-700' : 'bg-white border-gray-200 shadow-sm'}`}>
            <h2 className="text-sm font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-4">קטגוריות</h2>
            <div className="space-y-2">
              {['Work', 'Personal', 'Shopping', 'Health'].map(cat => (
                <button key={cat} className={`w-full flex items-center justify-between p-2 rounded-lg hover:bg-indigo-500/10 transition-colors text-sm`}>
                  <div className="flex items-center gap-2">
                    <Tag size={14} className="text-indigo-500" />
                    <span>{cat === 'Work' ? 'עבודה' : cat === 'Personal' ? 'אישי' : cat === 'Shopping' ? 'קניות' : 'בריאות'}</span>
                  </div>
                  <span className="text-[10px] px-2 py-0.5 rounded-full bg-gray-100 dark:bg-slate-700">
                    {tasks.filter(t => t.category === cat).length}
                  </span>
                </button>
              ))}
            </div>
          </div>
        </section>

        {/* Main Content Area */}
        <section className="lg:col-span-9 space-y-6">
          
          {/* Task Creation Form */}
          <form onSubmit={addTask} className={`p-4 rounded-2xl border transition-all ${isDarkMode ? 'bg-slate-800 border-slate-700' : 'bg-white border-gray-200 shadow-sm'}`}>
            <div className="flex flex-col md:flex-row gap-4">
              <input
                type="text"
                value={newTaskTitle}
                onChange={(e) => setNewTaskTitle(e.target.value)}
                placeholder="מה המשימה הבאה שלך?"
                className={`flex-1 px-4 py-3 rounded-xl outline-none focus:ring-2 focus:ring-indigo-500 transition-all ${isDarkMode ? 'bg-slate-700' : 'bg-gray-100'}`}
              />
              <div className="flex gap-2">
                <select 
                  value={newTaskPriority}
                  onChange={(e) => setNewTaskPriority(e.target.value)}
                  className={`px-3 py-3 rounded-xl outline-none text-sm font-medium ${isDarkMode ? 'bg-slate-700' : 'bg-gray-100'}`}
                >
                  <option value="low">עדיפות נמוכה</option>
                  <option value="medium">עדיפות בינונית</option>
                  <option value="high">עדיפות גבוהה</option>
                </select>
                <select 
                  value={newTaskCategory}
                  onChange={(e) => setNewTaskCategory(e.target.value)}
                  className={`px-3 py-3 rounded-xl outline-none text-sm font-medium ${isDarkMode ? 'bg-slate-700' : 'bg-gray-100'}`}
                >
                  <option value="Work">עבודה</option>
                  <option value="Personal">אישי</option>
                  <option value="Shopping">קניות</option>
                  <option value="Health">בריאות</option>
                </select>
                <button 
                  type="submit"
                  disabled={!newTaskTitle.trim()}
                  className="bg-indigo-600 hover:bg-indigo-700 text-white p-3 rounded-xl transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
                >
                  <Plus size={24} />
                </button>
              </div>
            </div>
          </form>

          {/* Filters and Controls */}
          <div className="flex flex-col md:flex-row md:items-center justify-between gap-4">
            <div className="flex items-center gap-2 overflow-x-auto pb-2 md:pb-0 no-scrollbar">
              <button 
                onClick={() => setFilter('all')}
                className={`px-4 py-1.5 rounded-full text-sm font-medium whitespace-nowrap transition-all ${filter === 'all' ? 'bg-indigo-600 text-white' : 'bg-gray-200 dark:bg-slate-700'}`}
              >
                הכל
              </button>
              <button 
                onClick={() => setFilter('active')}
                className={`px-4 py-1.5 rounded-full text-sm font-medium whitespace-nowrap transition-all ${filter === 'active' ? 'bg-indigo-600 text-white' : 'bg-gray-200 dark:bg-slate-700'}`}
              >
                פעילות
              </button>
              <button 
                onClick={() => setFilter('completed')}
                className={`px-4 py-1.5 rounded-full text-sm font-medium whitespace-nowrap transition-all ${filter === 'completed' ? 'bg-indigo-600 text-white' : 'bg-gray-200 dark:bg-slate-700'}`}
              >
                הושלמו
              </button>
            </div>

            <div className="flex items-center gap-3">
              <div className="relative">
                <Search size={16} className="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400" />
                <input 
                  type="text"
                  placeholder="חיפוש..."
                  value={searchQuery}
                  onChange={(e) => setSearchQuery(e.target.value)}
                  className={`pl-10 pr-4 py-1.5 rounded-full text-sm outline-none w-40 md:w-60 focus:ring-2 focus:ring-indigo-500 transition-all ${isDarkMode ? 'bg-slate-800' : 'bg-white border'}`}
                />
              </div>
              <div className="flex bg-gray-200 dark:bg-slate-700 rounded-lg p-1">
                <button 
                  onClick={() => setViewMode('list')}
                  className={`p-1.5 rounded-md transition-all ${viewMode === 'list' ? 'bg-white dark:bg-slate-600 shadow-sm' : ''}`}
                >
                  <ListIcon size={16} />
                </button>
                <button 
                  onClick={() => setViewMode('grid')}
                  className={`p-1.5 rounded-md transition-all ${viewMode === 'grid' ? 'bg-white dark:bg-slate-600 shadow-sm' : ''}`}
                >
                  <LayoutGrid size={16} />
                </button>
              </div>
            </div>
          </div>

          {/* Tasks Display */}
          {filteredTasks.length === 0 ? (
            <div className={`flex flex-col items-center justify-center py-20 rounded-3xl border-2 border-dashed ${isDarkMode ? 'border-slate-700' : 'border-gray-200'}`}>
              <div className="p-4 bg-gray-100 dark:bg-slate-800 rounded-full mb-4">
                <Search size={32} className="text-gray-400" />
              </div>
              <h3 className="text-lg font-medium">לא נמצאו משימות</h3>
              <p className="text-gray-500 text-sm">נסה לשנות את הפילטר או להוסיף משימה חדשה</p>
            </div>
          ) : (
            <div className={viewMode === 'list' ? 'space-y-3' : 'grid grid-cols-1 md:grid-cols-2 gap-4'}>
              {filteredTasks.map(task => (
                <div 
                  key={task.id}
                  className={`group relative p-4 rounded-2xl border transition-all hover:shadow-md ${
                    isDarkMode ? 'bg-slate-800 border-slate-700 hover:border-indigo-500/50' : 'bg-white border-gray-100 hover:border-indigo-200 shadow-sm'
                  } ${task.completed ? 'opacity-60' : ''}`}
                >
                  <div className="flex items-start gap-4">
                    <button 
                      onClick={() => toggleTask(task.id)}
                      className={`mt-1 transition-colors ${task.completed ? 'text-green-500' : 'text-gray-300 hover:text-indigo-500'}`}
                    >
                      {task.completed ? <CheckCircle2 size={22} /> : <Circle size={22} />}
                    </button>
                    
                    <div className="flex-1 min-w-0">
                      <div className="flex items-center gap-2 mb-1">
                        <span className={`text-[10px] uppercase font-bold px-2 py-0.5 rounded-md ${
                          task.priority === 'high' ? 'bg-red-500/10 text-red-500' : 
                          task.priority === 'medium' ? 'bg-orange-500/10 text-orange-500' : 
                          'bg-blue-500/10 text-blue-500'
                        }`}>
                          {task.priority === 'high' ? 'דחוף' : task.priority === 'medium' ? 'רגיל' : 'נמוך'}
                        </span>
                        <span className="text-[10px] text-gray-500 flex items-center gap-1">
                          <Tag size={10} />
                          {task.category}
                        </span>
                      </div>
                      <h4 className={`font-medium truncate transition-all ${task.completed ? 'line-through text-gray-500' : ''}`}>
                        {task.title}
                      </h4>
                      <p className="text-[10px] text-gray-400 mt-1 flex items-center gap-1">
                        <Clock size={10} />
                        {new Date(task.createdAt).toLocaleDateString('he-IL')}
                      </p>
                    </div>

                    <button 
                      onClick={() => deleteTask(task.id)}
                      className="opacity-0 group-hover:opacity-100 p-2 text-gray-400 hover:text-red-500 transition-all"
                    >
                      <Trash2 size={18} />
                    </button>
                  </div>
                </div>
              ))}
            </div>
          )}
        </section>
      </main>

      {/* Mobile Add Button Floating */}
      <div className="md:hidden fixed bottom-6 right-6">
        <button className="w-14 h-14 bg-indigo-600 rounded-full text-white shadow-lg flex items-center justify-center hover:scale-110 transition-transform active:scale-95">
          <Plus size={30} />
        </button>
      </div>
      
      {/* Footer Info */}
      <footer className="text-center py-8 text-sm text-gray-500">
        <p>© 2024 Task Master Pro. כל הזכויות שמורות.</p>
      </footer>

      {/* Global CSS for scrollbars */}
      <style dangerouslySetInnerHTML={{ __html: `
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
      `}} />
    </div>
  );
};

export default App;
